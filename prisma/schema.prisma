// South African Financial Compliance App - Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("USER") // USER | ADMIN
  createdAt    DateTime @default(now())
}

model Company {
  id              String   @id @default(cuid())
  name            String
  industry        String
  financialYearEnd String  // Format: YYYY-MM-DD
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trialBalances       TrialBalance[]
  reports             ComplianceReport[]
  financialStatements FinancialStatement[]
}

model TrialBalance {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  periodEnd DateTime // Financial period end date
  uploadedAt DateTime @default(now())

  entries             TrialBalanceEntry[]
  checkResults        ComplianceCheckResult[]
  reports             ComplianceReport[]
  financialStatement  FinancialStatement?

  @@index([companyId])
}

model TrialBalanceEntry {
  id             String   @id @default(cuid())
  trialBalanceId String
  trialBalance   TrialBalance @relation(fields: [trialBalanceId], references: [id], onDelete: Cascade)
  accountCode    String
  accountName    String
  debit          Decimal  @default(0)
  credit         Decimal  @default(0)

  @@index([trialBalanceId])
}

model ComplianceRule {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  category    String   // IFRS | COMPANIES_ACT | TAX | VALIDATION
  description String
  severity    String   // LOW | MEDIUM | HIGH
  enabled     Boolean  @default(true)
  config      String?  // JSON for rule-specific configuration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results     ComplianceCheckResult[]

  @@index([category])
  @@index([enabled])
}

model ComplianceCheckResult {
  id             String   @id @default(cuid())
  trialBalanceId String
  trialBalance   TrialBalance @relation(fields: [trialBalanceId], references: [id], onDelete: Cascade)
  ruleId         String
  rule           ComplianceRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  status         String   // COMPLIANT | WARNING | HIGH_RISK
  riskScore      Int      // 0-100
  message        String
  details        String?  // JSON for additional context
  createdAt      DateTime @default(now())

  @@index([trialBalanceId])
  @@index([ruleId])
}

model ComplianceReport {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trialBalanceId String
  trialBalance   TrialBalance @relation(fields: [trialBalanceId], references: [id], onDelete: Cascade)
  complianceScore Int     // 0-100
  riskLevel      String  // LOW | MEDIUM | HIGH
  summaryJson    String  // Executive summary, issues, recommendations
  generatedAt    DateTime @default(now())

  @@index([companyId])
  @@index([trialBalanceId])
}

model FinancialStatement {
  id             String       @id @default(cuid())
  trialBalanceId String       @unique
  companyId      String
  periodEnd      DateTime
  generatedAt    DateTime     @default(now())
  dataJson       String       // JSON of FinancialStatementsResult (income statement, balance sheet, cash flow)

  trialBalance   TrialBalance @relation(fields: [trialBalanceId], references: [id], onDelete: Cascade)
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}
